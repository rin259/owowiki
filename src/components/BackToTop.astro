<button
	type="button"
	class="back-to-top"
	data-back-to-top
	aria-label="返回顶部"
	title="返回顶部"
>
	↑
</button>

<script is:inline>
	const setupBackToTop = () => {
		const button = document.querySelector('[data-back-to-top]');
		if (!(button instanceof HTMLButtonElement)) return;
		if (button.dataset.bound === 'true') {
			button.dataset.visible = window.scrollY > 360 ? 'true' : 'false';
			return;
		}

		const toggleVisibility = () => {
			button.dataset.visible = window.scrollY > 360 ? 'true' : 'false';
		};

		const flashButton = () => {
			button.dataset.pressed = 'true';
			window.setTimeout(() => {
				delete button.dataset.pressed;
			}, 180);
		};

		const scrollToTop = () => {
			const topAnchor =
				document.getElementById('_top') ??
				document.querySelector('[data-page-title]') ??
				document.body;

			if (topAnchor instanceof HTMLElement) {
				topAnchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}

			const scroller = document.scrollingElement;
			if (scroller) {
				scroller.scrollTo({ top: 0, behavior: 'smooth' });
			} else {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			}
		};

		button.dataset.bound = 'true';
		button.addEventListener('click', () => {
			flashButton();
			scrollToTop();
		});

		toggleVisibility();
		window.addEventListener('scroll', toggleVisibility, { passive: true });
	};

	document.addEventListener('astro:page-load', setupBackToTop);

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupBackToTop, { once: true });
	} else {
		setupBackToTop();
	}
</script>
